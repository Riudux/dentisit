<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#DDE1E8"> <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgDentistaFoto"
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:src="@drawable/ic_dentist_logo"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/btnMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_more"
        android:tint="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="UseAppTint" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/imgDentistaFoto"
        app:layout_constraintStart_toEndOf="@id/imgDentistaFoto"
        app:layout_constraintEnd_toStartOf="@id/btnMenu">

        <TextView
            android:id="@+id/tvDentistaNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dr.Sebastian"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDentistaEspecialidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-Ortodoncia"
            android:textColor="#757575"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_dialog_map"
                android:tint="#333333"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/tvDentistaDireccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blvr. Dolores del rio"
                android:textColor="#333333"
                android:textSize="12sp"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <RatingBar
            android:id="@+id/ratingDentista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="?android:attr/ratingBarStyleSmall"
            android:numStars="5"
            android:stepSize="1"
            android:rating="3"
            android:layout_marginTop="8dp"
            android:progressTint="#FFD700"/> </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>