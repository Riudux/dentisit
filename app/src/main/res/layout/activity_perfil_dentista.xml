<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DDE1E8"> <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/constraintHeader"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:background="#2E4072"
    android:padding="24dp"
    app:layout_constraintTop_toTopOf="parent">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgProfile"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:src="@drawable/ic_dentist_logo"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Hola Richi!"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/imgProfile"
        app:layout_constraintBottom_toBottomOf="@id/imgProfile"
        app:layout_constraintStart_toEndOf="@id/imgProfile" />

    <EditText
        android:id="@+id/etSearchProfile"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input_field"
        android:hint="Doctor o Espacialidad"
        android:textColor="#FFFFFF"
        android:textColorHint="#DDE1E8"
        android:drawableEnd="@android:drawable/ic_menu_search"
        android:paddingEnd="15dp"
        android:paddingStart="15dp"
        app:layout_constraintTop_toBottomOf="@id/imgProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="TextFields" />

</androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutIdentity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#37A7C0"
        android:paddingVertical="20dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/constraintHeader">

        <ImageView
            android:id="@+id/imgDienteLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_dialog_map"
            android:tint="#FFFFFF"
            tools:ignore="UseAppTint" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvPerfilNombreDentista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRA. CARLA RODRÍGUEZ"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvPerfilClinicaNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLÍNICA DENTAL"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:letterSpacing="0.3"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/gridLayoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:columnCount="2"
        app:rowCount="2"
        app:layout_constraintTop_toBottomOf="@id/layoutIdentity">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_columnWeight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#AFBFBA"> <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Inicio"
            android:textColor="#333333"
            android:textSize="18sp"
            android:gravity="center" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_columnWeight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#AFBFBA">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Ubicacion"
                android:textColor="#333333"
                android:textSize="18sp"
                android:gravity="center" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_columnWeight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#6BAF9A"> <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Agendar cita"
            android:textColor="#333333"
            android:textSize="18sp"
            android:gravity="center" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_columnWeight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#AFBFBA">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Citas"
                android:textColor="#333333"
                android:textSize="18sp"
                android:gravity="center" />
        </androidx.cardview.widget.CardView>
    </androidx.gridlayout.widget.GridLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProximasCitas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#B6C2BF"
        app:layout_constraintTop_toBottomOf="@id/gridLayoutButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proximas citas"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvCitaDoctorEspecialidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Juan Perez - Odontología"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvCitaFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy, 3:00 p.m"
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnComoLlegar"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:text="Como llegar"
                android:textColor="#333333"
                android:background="@drawable/bg_social_button"
                android:backgroundTint="#6BAF9A"
                android:layout_gravity="center" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>